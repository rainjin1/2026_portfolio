#include <stdio.h>      // printf, 입출력 함수
#include <string.h>     // strlen, memset 등 문자열/메모리 함수
#include <unistd.h>     // close, read, write 등 유닉스 시스템 콜
#include <arpa/inet.h>  // sockaddr_in, htons 등 네트워크 관련 함수

int main() {

    // 1️⃣ 서버 소켓과 클라이언트 소켓 변수 선언
    // server_fd : 서버 소켓 (listen용)
    // client_fd : 클라이언트와 연결된 소켓
    int server_fd, client_fd;

    // 2️⃣ 서버 주소 정보를 담는 구조체 선언
    // sockaddr_in : IPv4 전용 소켓 주소 구조체
    struct sockaddr_in server_addr;

    // 3️⃣ 클라이언트 요청 데이터를 저장할 버퍼
    char buffer[1024];

    // ----------------------------------------------------
    // 4️⃣ 소켓 생성
    // ----------------------------------------------------
    // socket(int domain, int type, int protocol)
    // domain : AF_INET (IPv4)
    // type   : SOCK_STREAM (TCP)
    // protocol : 0 (기본 TCP)
    server_fd = socket(AF_INET, SOCK_STREAM, 0);

    // ----------------------------------------------------
    // 5️⃣ 서버 주소 초기화
    // ----------------------------------------------------
    memset(&server_addr, 0, sizeof(server_addr)); // 구조체 전체를 0으로 초기화

    server_addr.sin_family = AF_INET;       // 주소 체계: IPv4
    server_addr.sin_port = htons(8080);     // 포트 번호 설정 (호스트 바이트 -> 네트워크 바이트)
    server_addr.sin_addr.s_addr = INADDR_ANY; // 모든 네트워크 인터페이스에서 접속 허용

    // ----------------------------------------------------
    // 6️⃣ bind 함수 : 소켓에 IP와 포트 연결
    // ----------------------------------------------------
    // bind(int sockfd, const struct sockaddr *addr, socklen_t addrlen)
    // - sockfd : 연결할 소켓
    // - addr   : 연결할 주소 구조체
    // - addrlen : 구조체 크기
    // bind 역할 : "이 소켓이 8080 포트를 사용하겠다" 선언
    bind(server_fd, (struct sockaddr*)&server_addr, sizeof(server_addr));

    // ----------------------------------------------------
    // 7️⃣ listen 함수 : 서버 소켓을 "대기 상태"로 변경
    // ----------------------------------------------------
    // listen(int sockfd, int backlog)
    // - sockfd : 서버 소켓
    // - backlog : 동시에 대기 가능한 연결 수
    // listen 역할 : 클라이언트가 접속 요청할 때까지 기다리는 상태로 변경
    listen(server_fd, 5);

    printf("Server started on port 8080\n");

    // ----------------------------------------------------
    // 8️⃣ accept 함수 : 클라이언트 연결 수락
    // ----------------------------------------------------
    // accept(int sockfd, struct sockaddr *addr, socklen_t *addrlen)
    // - sockfd : listen 중인 서버 소켓
    // - addr : 접속한 클라이언트 주소를 받을 구조체 (NULL 가능)
    // - addrlen : 구조체 크기 (NULL 가능)
    // accept 역할 : 클라이언트가 접속하면 새 소켓(client_fd)을 생성하고 연결
    client_fd = accept(server_fd, NULL, NULL);

    // ----------------------------------------------------
    // 9️⃣ recv 함수 : 클라이언트 요청 수신
    // ----------------------------------------------------
    // recv(int sockfd, void *buf, size_t len, int flags)
    // - sockfd : 클라이언트 소켓
    // - buf : 데이터를 저장할 버퍼
    // - len : 최대 읽을 바이트 수
    // - flags : 기본 0
    // recv 역할 : TCP 소켓에서 클라이언트가 보낸 데이터를 읽음
    recv(client_fd, buffer, sizeof(buffer), 0);

    printf("Request received:\n%s\n", buffer);

    // ----------------------------------------------------
    // 🔟 HTTP 응답 생성
    // ----------------------------------------------------
    // HTTP는 단순한 텍스트 프로토콜
    // 문자열로 상태 코드, 헤더, 콘텐츠를 작성
    char response[] =
        "HTTP/1.1 200 OK\r\n"        // 상태 코드 200 (성공)
        "Content-Type: text/html\r\n" // 응답 데이터 형식: HTML
        "\r\n"                        // 헤더 끝 표시 (중요!)
        "<h1>Hello from my C server</h1>"; // 실제 HTML 콘텐츠

    // ----------------------------------------------------
    // 11️⃣ send 함수 : 클라이언트에 응답 전송
    // ----------------------------------------------------
    // send(int sockfd, const void *buf, size_t len, int flags)
    // - sockfd : 클라이언트 소켓
    // - buf : 보낼 데이터
    // - len : 데이터 길이
    // - flags : 기본 0
    // send 역할 : TCP 소켓을 통해 데이터를 클라이언트에 보냄
    send(client_fd, response, strlen(response), 0);

    // ----------------------------------------------------
    // 12️⃣ close : 소켓 닫기
    // ----------------------------------------------------
    // 클라이언트 소켓 종료
    close(client_fd);

    // 서버 소켓 종료
    close(server_fd);

    return 0;
}
