#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>
#include <sys/socket.h>

void error_handling(const char *message);

int main(int argc, char *argv[])
{
    int serv_sock, clnt_sock;
    struct sockaddr_in serv_addr, clnt_addr;
    socklen_t clnt_addr_size;

    char buffer[1024]; 
    int str_len;

    // 127.0.0.1을 코드에 고정했으므로, 이제 포트번호만 인자로 받습니다 (argc != 2)
    if (argc != 2) {
        printf("Usage : %s <port>\n", argv[0]);
        exit(1);
    }

    // 1. 소켓 생성
    serv_sock = socket(PF_INET, SOCK_STREAM, 0);
    if (serv_sock == -1)
        error_handling("socket() error");

    // 포트 재사용 설정
    int option = 1;
    setsockopt(serv_sock, SOL_SOCKET, SO_REUSEADDR, &option, sizeof(option));

    // 주소 설정 (로컬 호스트로 고정)
    memset(&serv_addr, 0, sizeof(serv_addr));
    serv_addr.sin_family = AF_INET;
    serv_addr.sin_addr.s_addr = inet_addr("127.0.0.1"); // 로컬 IP 고정
    serv_addr.sin_port = htons(atoi(argv[1]));          // 인자의 첫 번째인 포트번호 사용

    // 2. 주소 할당 (bind)
    if (bind(serv_sock, (struct sockaddr*)&serv_addr, sizeof(serv_addr)) == -1)
        error_handling("bind() error");

    // 3. 연결 대기 (listen)
    if (listen(serv_sock, 5) == -1)
        error_handling("listen() error");

    printf("Server started on 127.0.0.1:%s\n", argv[1]);

    clnt_addr_size = sizeof(clnt_addr);

    // 4. 클라이언트 수락 (accept)
    clnt_sock = accept(serv_sock, (struct sockaddr*)&clnt_addr, &clnt_addr_size);
    if (clnt_sock == -1)
        error_handling("accept() error");
    
    printf("Client connected!\n");

    // 5. 데이터 읽기 및 출력 루프
    while (1) {
        memset(buffer, 0, sizeof(buffer));

        str_len = read(clnt_sock, buffer, sizeof(buffer) - 1);

        // 클라이언트가 접속을 끊었을 때 처리
        if (str_len <= 0) {
            printf("Client disconnected.\n");
            break;
        }

        // [논리오류 수정] strcmp는 같을 때 0을 반환하므로 == 0 체크가 필수입니다.
        if (strcmp(buffer, "123") == 0 || strcmp(buffer, "123\n") == 0) 
        {
            printf("Exit signal '123' received. Closing server...\n");
            break;
        }

        // 읽어온 데이터 출력
        printf("Received data: %s\n", buffer);
        fflush(stdout); // 이 한 줄을 추가해보세요.
    }

    // 6. 종료
    close(clnt_sock);
    close(serv_sock);

    return 0;
}

void error_handling(const char *message)
{
    fputs(message, stderr);
    fputc('\n', stderr);
    exit(1);
}
